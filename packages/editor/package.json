{
  "name": "@rte/editor",
  "version": "0.0.0",
  "description": "ProseMirror-based markdown editor (Typora-style).",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./style.css": "./src/style.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/index.mjs",
      "./style.css": "./dist/style.css",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "markdown-it": "^14.1.0",
    "prosemirror-commands": "^1.5.2",
    "prosemirror-history": "^1.4.1",
    "prosemirror-inputrules": "catalog:",
    "prosemirror-keymap": "^1.2.2",
    "prosemirror-model": "catalog:",
    "prosemirror-schema-list": "catalog:",
    "prosemirror-state": "^1.4.3",
    "prosemirror-view": "^1.33.7"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.0",
    "@types/node": "^25.6.2",
    "jsdom": "catalog:",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.20"
  }
}
